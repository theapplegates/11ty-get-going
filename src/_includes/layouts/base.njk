<!DOCTYPE html>
<html lang="en">
  <head>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cloudinary-core/2.13.1/cloudinary-core-shrinkwrap.js" integrity="sha512-O81/zueLJzorJhHKGYGaNBlFiHXw/iKhHzo+bWDXmhcLF2bH4WA9/Ts2qtFiqjpVnyQFQsnlxWYTugpOw7BtEw==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    {% include "partials/base-head.njk" %}
  </head>

  <body>
    {% include "partials/site-header.njk" %}
    <main id="main-content">
      {% block content %}{% endblock %}
    </main>
    {% include "partials/site-footer.njk" %}
  </body>
  <script type="text/javascript">
      my_breakpoints = function (width){  // width - the current width of the containing element
        return 40 * Math.ceil(width / 40);
      }
      var cl = cloudinary.Cloudinary.new({cloud_name: "paulapplegate-com"}); 
         cl.config({breakpoints:my_breakpoints, responsive_use_breakpoints:"resize"})
      cl.responsive();
  </script>

</html>